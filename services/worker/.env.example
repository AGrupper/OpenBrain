# Local Worker dev uses .dev.vars, not .env:
#   Copy this file to services/worker/.dev.vars for `wrangler dev`.
#
# Deployed Worker secrets are set separately:
#   wrangler secret put SUPABASE_URL
#   wrangler secret put SUPABASE_SERVICE_KEY
#   wrangler secret put TELEGRAM_BOT_TOKEN
#   wrangler secret put OPENBRAIN_AUTH_TOKEN

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-personal-chat-id
OPENBRAIN_AUTH_TOKEN=a-long-random-secret-you-choose

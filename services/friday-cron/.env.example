# Fill these in and source before running, or add to Friday's cron environment
OPENBRAIN_API_URL=https://openbrain-worker.your-subdomain.workers.dev
OPENBRAIN_AUTH_TOKEN=same-token-as-worker

# Friday's own model API key (whichever provider she uses)
# The embedding call is configurable in linker.ts
EMBEDDING_PROVIDER=voyage        # or: openai, anthropic
VOYAGE_API_KEY=                   # if using Voyage
OPENAI_API_KEY=                   # if using OpenAI embeddings
ANTHROPIC_API_KEY=                # if using Anthropic

# Friday's reasoning model API key (for link evaluation and tagging)
FRIDAY_MODEL_PROVIDER=anthropic   # or: openai, etc.
FRIDAY_MODEL=claude-opus-4-7     # adjust to whichever Friday runs on

# Limit per cron run to control token spend
MAX_FILES_PER_RUN=20
